{
  "name": "test-harness",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/xinyao27/test-harness#readme",
  "bugs": {
    "url": "https://github.com/xinyao27/test-harness/issues"
  },
  "license": "MIT",
  "author": {
    "name": "xinyao",
    "email": "hi@xinyao.me"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xinyao27/test-harness.git"
  },
  "funding": "https://github.com/sponsors/xinyao27",
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm -r --parallel run dev",
    "build": "vp run --filter './packages/*' build && pnpm --filter './apps/*' run build",
    "check": "vp check --fix",
    "lint": "vp lint --fix",
    "fmt": "vp fmt",
    "test": "vp test",
    "example:todo:check": "pnpm example:todo-spec-map:check && pnpm example:todo-feature-map:check",
    "example:todo-client": "pnpm --dir examples/todo-backend/client/todomvc-react dev",
    "example:todo-client:build": "pnpm --dir examples/todo-backend/client/todomvc-react build",
    "example:todo-feature-map:check": "node examples/todo-backend/tools/check-feature-map.mjs",
    "example:todo-spec-map:check": "node examples/todo-backend/tools/check-spec-map.mjs",
    "ready": "vp check && vp run -r test && vp run -r build",
    "up": "taze major -Ir",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@test-harness/adapter-vitest": "workspace:*",
    "taze": "catalog:",
    "vite-plus": "catalog:",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.2.2"
}
